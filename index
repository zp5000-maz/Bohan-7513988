<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>博瀚 AI 英語 V53.0</title>
    <style>
        :root { --primary: #ffc107; --bg: #000; --card: #111; --success: #00ffbb; --danger: #ff4444; }
        body { font-family: system-ui, sans-serif; background: var(--bg); color: #fff; margin: 0; display: flex; justify-content: center; align-items: center; min-height: 100vh; overflow: hidden; }
        .card { background: var(--card); padding: 25px; border-radius: 30px; width: 92%; max-width: 420px; text-align: center; border: 1px solid #333; position: relative; }
        .hidden { display: none !important; }
        
        /* 調整彈窗位置：移動到題目下方，避免被網址列遮擋 */
        #toast { 
            position: absolute; top: 160px; left: 50%; transform: translateX(-50%);
            width: 80%; font-weight: 900; z-index: 100; 
            opacity: 0; transition: 0.3s; pointer-events: none;
            background: rgba(34,34,34,0.95); padding: 15px;
            border-radius: 20px; border: 1px solid #444;
            display: flex; flex-direction: column; align-items: center; gap: 5px;
        }
        #toast-icon { font-size: 50px; }
        #toast-text { font-size: 24px; }
        .toast-show { opacity: 1 !important; transform: translateX(-50%) translateY(10px) !important; }

        #ktv-box { font-size: 28px; font-weight: bold; line-height: 1.3; margin: 15px 0; display: flex; flex-wrap: wrap; justify-content: center; gap: 6px; min-height: 70px; }
        .word { color: #fff; transition: 0.2s; }
        .word.active { color: var(--primary); text-shadow: 0 0 10px var(--primary); transform: scale(1.1); }
        
        /* 語速控制列樣式 */
        .speed-ctrl { margin: 10px 0; background: #222; padding: 10px; border-radius: 15px; display: flex; align-items: center; gap: 10px; }
        .speed-ctrl label { font-size: 14px; color: #aaa; white-space: nowrap; }
        input[type=range] { flex: 1; accent-color: var(--primary); }

        .score-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 10px; margin: 15px 0; background: #1a1a1a; padding: 15px; border-radius: 20px; }
        .score-item b { font-size: 24px; color: var(--success); display: block; }
        #total-score { font-size: 70px; font-weight: 900; color: var(--success); margin: 0; line-height: 1; }
        .low-score { color: var(--danger) !important; }

        .btn { width: 100%; padding: 18px; border-radius: 16px; border: none; font-size: 18px; font-weight: bold; cursor: pointer; margin-top: 10px; }
        .btn-primary { background: var(--primary); color: #000; }
        .btn-dark { background: #222; color: #fff; border: 1px solid #444; }
        #queue-status { font-size: 10px; color: #555; margin-top: 8px; }
        .login-input { width: 100%; padding: 20px; margin-bottom: 15px; border-radius: 15px; border: 2px solid #333; background: #222; color: #fff; text-align: center; font-size: 22px; box-sizing: border-box; }
    </style>
</head>
<body>

<div id="toast">
    <div id="toast-icon">👍</div>
    <div id="toast-text">太棒了！</div>
</div>

<div class="card">
    <div id="login-ui">
        <h2 style="color:var(--primary); font-size: 26px; margin-bottom: 20px;">博瀚 AI 教室</h2>
        <input type="text" id="user" class="login-input" placeholder="姓名">
        <input type="password" id="pass" class="login-input" placeholder="密碼">
        <button id="login-btn" class="btn btn-primary" onclick="doLogin()">進入系統</button>
        <div id="init-loader" style="margin-top:15px; color:#555;">連線檢查中...</div>
    </div>

    <div id="main-ui" class="hidden">
        <div id="ktv-box">載入中...</div>
        <div id="chi-box" style="color:var(--primary); font-size:16px; font-weight:bold;"></div>
        
        <div class="speed-ctrl">
            <label>🐢 語速</label>
            <input type="range" id="speed-range" min="0.5" max="1.2" step="0.1" value="0.8">
            <label>🐇</label>
        </div>

        <div id="total-score">0</div>
        
        <div class="score-grid">
            <div class="score-item"><b id="s-f">0</b><span>流暢</span></div>
            <div class="score-item"><b id="s-c">0</b><span>完整</span></div>
            <div class="score-item"><b id="s-q">0</b><span>清晰</span></div>
        </div>

        <canvas id="wave" style="width:100%;height:35px;background:#000;border-radius:10px;"></canvas>
        
        <div style="display:flex; gap:10px; margin-top:10px;">
            <button class="btn btn-dark" style="flex:1" onclick="playFullLesson()">🔊 範讀</button>
            <button id="rec-btn" class="btn btn-dark" style="flex:2; color:var(--success);" onclick="toggleRec()">🎙️ 錄音評分</button>
        </div>
        <button id="next-btn" class="btn btn-primary" onclick="fastNext()" disabled>下一題 ➔</button>
        <div id="queue-status">雲端同步中...</div>
    </div>
</div>

<script>
    const API = "你的_GAS_網址"; 
    let db = { users:[], questions:[] }, stu = "", cur = 0, isRec = false, latestResult = "", audioBlob = null;
    let audioCtx, ana, anim, rec, uploadQueue = 0;

    async function init() {
        try {
            const r = await fetch(`${API}?t=${new Date().getTime()}`);
            const data = await r.json();
            if(data.users) { db = data; document.getElementById('init-loader').innerText = "連線成功 ✓"; }
        } catch(e) { setTimeout(init, 3000); }
    }
    window.onload = init;

    function doLogin() {
        const u = document.getElementById('user').value.trim();
        const p = document.getElementById('pass').value.trim();
        const found = db.users.find(x => String(x[0]) === u && String(x[1]) === p);
        if(found) { stu = u; document.getElementById('login-ui').classList.add('hidden'); document.getElementById('main-ui').classList.remove('hidden'); renderQ(); } else { alert("帳密錯誤"); }
    }

    function renderQ() {
        const q = db.questions[cur];
        document.getElementById('ktv-box').innerHTML = q.eng.split(" ").map((w, i) => `<span class="word" id="w-${i}">${w}</span>`).join("");
        document.getElementById('chi-box').innerText = q.chi;
        document.getElementById('total-score').innerText = "0";
        document.getElementById('next-btn').disabled = true;
    }

    // 支援語速調整的朗讀功能
    function playFullLesson() {
        window.speechSynthesis.cancel();
        const q = db.questions[cur];
        const speed = parseFloat(document.getElementById('speed-range').value);
        const utEng = new SpeechSynthesisUtterance(q.eng);
        utEng.lang = 'en-US'; 
        utEng.rate = speed;   
        utEng.volume = 1.0; 
        
        let wordIdx = 0;
        utEng.onboundary = (e) => {
            if (e.name === 'word') {
                const spans = document.querySelectorAll('.word');
                spans.forEach(s => s.classList.remove('active'));
                if(spans[wordIdx]) { spans[wordIdx].classList.add('active'); wordIdx++; }
            }
        };
        utEng.onend = () => { 
            setTimeout(() => { 
                document.querySelectorAll('.word').forEach(w => w.classList.remove('active')); 
                const utChi = new SpeechSynthesisUtterance(q.chi);
                utChi.lang = 'zh-TW'; utChi.rate = 1.0; utChi.volume = 1.0;
                window.speechSynthesis.speak(utChi);
            }, 300); 
        };
        window.speechSynthesis.speak(utEng);
    }

    function showToast(icon, text, color) { 
        const t = document.getElementById('toast');
        document.getElementById('toast-icon').innerText = icon;
        document.getElementById('toast-text').innerText = text;
        t.style.color = color;
        t.classList.add('toast-show');
        setTimeout(() => t.classList.remove('toast-show'), 2000);
    }

    async function toggleRec() {
        if(!audioCtx) audioCtx = new (window.AudioContext || window.webkitAudioContext)();
        if(!isRec) {
            const stream = await navigator.mediaDevices.getUserMedia({audio:true});
            ana = audioCtx.createAnalyser(); audioCtx.createMediaStreamSource(stream).connect(ana);
            const cvs = document.getElementById('wave'), c = cvs.getContext('2d'), data = new Uint8Array(ana.frequencyBinCount);
            const draw = () => {
                ana.getByteFrequencyData(data);
                c.fillStyle = '#000'; c.fillRect(0,0,cvs.width,cvs.height);
                for(let i=0; i<60; i++) { let h = data[i*2]/2; c.fillStyle = `hsl(${i*4+180},100%,50%)`; c.fillRect(i*7, cvs.height-h, 5, h); }
                anim = requestAnimationFrame(draw);
            }; draw();
            const mr = new MediaRecorder(stream); let chunks = [];
            mr.ondataavailable = e => chunks.push(e.data);
            mr.onstop = () => { audioBlob = new Blob(chunks, {type:'audio/webm'}); };
            mr.start();
            const Recognition = window.webkitSpeechRecognition || window.SpeechRecognition;
            rec = new Recognition(); rec.lang = 'en-US'; rec.interimResults = true; 
            rec.onresult = e => { latestResult = e.results[e.results.length - 1][0].transcript.toLowerCase(); };
            rec.start(); isRec = true;
            document.getElementById('rec-btn').innerText = "⏹ 停止評分";
            window.currentMR = mr;
        } else {
            isRec = false; if(rec) rec.stop(); if(window.currentMR) window.currentMR.stop();
            cancelAnimationFrame(anim);
            document.getElementById('rec-btn').innerText = "🎙️ 錄音評分";
            calculateAI();
        }
    }

    function calculateAI() {
        const target = db.questions[cur].eng.toLowerCase().split(/\s+/);
        const spoken = latestResult.split(/\s+/);
        let matches = 0;
        target.forEach(word => { if(spoken.includes(word.replace(/[.,!?]/g,""))) matches++; });
        const matchRate = (matches / target.length);
        let f = Math.min(10, Math.floor(matchRate * 8 + 5)); 
        let c = Math.min(10, Math.floor(matchRate * 7 + 6)); 
        let q = Math.min(10, Math.floor(matchRate * 8 + 5));
        if (latestResult.trim() === "" || matches === 0) { f = 1; c = 2; q = 1; }
        const total = f + c + q;
        document.getElementById('s-f').innerText = f; 
        document.getElementById('s-c').innerText = c; 
        document.getElementById('s-q').innerText = q;
        document.getElementById('total-score').innerText = total;

        if (total < 15) {
            document.getElementById('total-score').classList.add('low-score');
            showToast("😡", "請認真練習！", "#ff4444");
        } else {
            document.getElementById('total-score').classList.remove('low-score');
            if (total >= 25) showToast("👍", "太棒了！", "#00ffbb");
        }
        document.getElementById('next-btn').disabled = false;
    }

    function fastNext() {
        const scoreData = { student: stu, eng: db.questions[cur].eng, score: document.getElementById('total-score').innerText, f: document.getElementById('s-f').innerText, c: document.getElementById('s-c').innerText, q: document.getElementById('s-q').innerText, blob: audioBlob };
        processUpload(scoreData); cur++;
        if(db.questions[cur]) renderQ(); else {
            document.getElementById('main-ui').innerHTML = "<h2 style='color:var(--primary)'>🎉 功課完成！</h2>";
            setTimeout(() => location.reload(), 2000);
        }
    }

    async function processUpload(data) {
        uploadQueue++; updateQueueUI();
        let base64 = "";
        if(data.blob) { const reader = new FileReader(); base64 = await new Promise(res => { reader.onloadend = () => res(reader.result.split(',')[1]); reader.readAsDataURL(data.blob); }); }
        fetch(API, { method: 'POST', mode: 'no-cors', body: JSON.stringify({ ...data, audioData: base64 }) })
        .then(() => { uploadQueue--; updateQueueUI(); }).catch(() => { uploadQueue--; updateQueueUI(); });
    }
    function updateQueueUI() { document.getElementById('queue-status').innerText = uploadQueue > 0 ? `剩餘 ${uploadQueue} 題同步中...` : "同步完成 ✓"; }
</script>
</body>
</html>
